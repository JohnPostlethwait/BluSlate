{
  "name": "@bluslate/cli",
  "version": "0.2.7",
  "description": "CLI frontend for BluSlate — rename TV show files using TMDb metadata",
  "type": "module",
  "bin": {
    "bluslate": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "start": "node ./dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "ISC",
  "dependencies": {
    "@bluslate/core": "workspace:*",
    "@ffprobe-installer/ffprobe": "^2.1.0",
    "@inquirer/prompts": "^8.2.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
