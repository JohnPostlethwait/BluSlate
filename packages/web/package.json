{
  "name": "@bluslate/web",
  "version": "0.2.6",
  "description": "Web server for BluSlate — run in Docker as a browser-accessible app",
  "type": "module",
  "scripts": {
    "dev": "vite build && tsup --watch --onSuccess 'node dist/server/index.js'",
    "build": "vite build && tsup",
    "preview": "node dist/server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "ISC",
  "dependencies": {
    "@bluslate/core": "workspace:*",
    "@bluslate/ui": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^8.1.0",
    "fastify": "^5.3.3",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^25.2.1",
    "socket.io-client": "^4.8.1",
    "svelte": "^5.51.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  },
  "tsup": {
    "entry": [
      "src/server/index.ts"
    ],
    "outDir": "dist/server",
    "format": [
      "esm"
    ],
    "target": "node22",
    "clean": true,
    "sourcemap": true
  }
}
