<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required by Electron's V8 engine for JIT compilation -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Required by Electron for unsigned executable memory (V8) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Required by Electron helper processes -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Outbound network access for TMDb API calls -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- TODO: Uncomment when code signing is configured for notarization -->
    <!-- <key>com.apple.security.cs.disable-library-validation</key> -->
    <!-- <true/> -->
</dict>
</plist>
