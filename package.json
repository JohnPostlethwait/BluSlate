{
  "name": "bluslate",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform tool to rename TV show files using TMDb metadata",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r run typecheck",
    "start": "pnpm --filter @bluslate/cli run start",
    "generate-icon": "node scripts/generate-icon.mjs",
    "package:gui": "pnpm --filter @bluslate/core run build && pnpm --filter @bluslate/gui run build && pnpm --filter @bluslate/gui run package"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "media",
    "rename",
    "tmdb",
    "tv",
    "shows",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@ffprobe-installer/darwin-arm64",
      "@ffprobe-installer/ffprobe",
      "electron",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "tar": ">=7.5.8",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=5.0.0 <5.1.7": ">=5.1.7",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "minimatch@>=10.0.0 <10.2.1": ">=10.2.1"
    }
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "sharp": "^0.34.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
