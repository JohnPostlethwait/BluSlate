{
  "name": "mediafetch",
  "version": "0.1.0",
  "description": "Cross-platform CLI tool to rename TV show and movie files using TMDb metadata",
  "type": "module",
  "bin": {
    "mediafetch": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "node ./dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "media",
    "rename",
    "tmdb",
    "tv",
    "movies",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@ctrl/video-filename-parser": "^5.4.1",
    "@inquirer/prompts": "^8.2.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
