{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@bluslate/core": ["./packages/core/src/index.ts"],
      "@bluslate/core/*": ["./packages/core/src/*"]
    }
  },
  "include": ["packages/*/src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
